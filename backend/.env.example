# Double Agent Backend Configuration

# Application
DEBUG=false
APP_NAME="Double Agent API"

# Database
DATABASE_URL="sqlite+aiosqlite:///./double_agent.db"

# CORS (for development)
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

# API Keys for LLM Providers
# At least one of these must be configured for the backend to work

# OpenAI / OpenAI-compatible (OpenAI, DeepSeek, Qwen, Kimi, GLM, etc.)
OPENAI_API_KEY=sk-...
# Optional: Override base URL for OpenAI-compatible providers
# OPENAI_BASE_URL=https://api.openai.com

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: Override base URL for Anthropic
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Default model configurations (optional)
# These are used when the frontend doesn't specify a model
DEFAULT_GENTLE_MODEL=gpt-4o
DEFAULT_ANGRY_MODEL=gpt-4o
DEFAULT_GENTLE_TEMPERATURE=0.7
DEFAULT_ANGRY_TEMPERATURE=0.8
